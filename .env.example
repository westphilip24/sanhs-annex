# Cloudflare Pages — Environment Variables
# Copy to .env and fill in values

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Database (D1) — binding name matches wrangler.toml
# For local dev with Wrangler: "local"
# For production (CF Pages): the binding name "DB"
DB="local"

# Optional: R2 for file uploads
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="sanhs-annex-uploads"
